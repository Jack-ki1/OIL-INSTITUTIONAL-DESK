# =============================================================================
# Oil Session Radar - Institutional Desk :: environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in only the keys you have. The app boots and
# runs fully in Simulated Demo Mode with ZERO of these set. Adding keys unlocks
# Live Data Mode for the panels that can be real (price, volume, news).
# =============================================================================

# --- Refresh cadence (seconds) -----------------------------------------------
REFRESH_SECONDS=5
LIVE_REFRESH_SECONDS=60

# --- Market / news data providers --------------------------------------------
# yfinance needs NO key (WTI/Brent price + volume + backtest history work free).
# NewsAPI: https://newsapi.org/register  (free tier available)
NEWSAPI_API_KEY=
# U.S. EIA open data: https://www.eia.gov/opendata/register.php  (free)
EIA_API_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key  (free)
ALPHA_VANTAGE_API_KEY=

# --- Alert channel: Email (SMTP) ---------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --- Alert channel: SMS (Twilio) ---------------------------------------------
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# --- Alert channel: Telegram -------------------------------------------------
# Create a bot with @BotFather, then get your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
